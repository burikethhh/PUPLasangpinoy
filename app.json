{
  "expo": {
    "name": "FOODFIX",
    "slug": "foodfix",
    "version": "2.6.0",
    "orientation": "portrait",
    "icon": "./logo.jpg",
    "scheme": "foodfix",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.foodfix.mobile",
      "buildNumber": "12"
    },
    "android": {
      "package": "com.foodfix.mobile",
      "versionCode": 12,
      "adaptiveIcon": {
        "foregroundImage": "./logo.jpg",
        "backgroundColor": "#F5EDD9"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#F5EDD9",
          "dark": {
            "backgroundColor": "#1A1008"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#F25C05",
          "sounds": []
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "446b4bd5-8373-4cd2-b91c-ff5e8f4d5eac"
      },
      "router": {}
    },
    "owner": "keth"
  }
}
